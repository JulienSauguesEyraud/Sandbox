{# templates/home/show.html.twig #}

{% extends 'base.html.twig' %}

{% block body %}
    {% if app.user %}
        <h1>Bonjour {{ app.user.email }}</h1>
        <a href="{{ path('app_logout') }}">Se déconnecter</a>
    {% else %}
        <h1>Bienvenue</h1>
        <a href="{{ path('app_login') }}">Se connecter</a>
        <a href="{{ path('app_register') }}">S'inscrire</a>
    {% endif %}
{% endblock %}
