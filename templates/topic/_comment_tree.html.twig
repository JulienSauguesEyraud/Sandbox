<span style="display:block; margin-left: 35px; border-left: 1px solid black;">
    ----
    {% if comment.description|length > 80 %}
        <span class="comment-short">
            {{ comment.description|slice(0, 80) }}
            <span onclick="toggleComment(this)" style="cursor:pointer; color:blue;">
                ... [voir plus]
            </span>
        </span>
        <span class="comment-full" style="display:none;">
            {{ comment.description }}
            <span onclick="toggleComment(this)" style="cursor:pointer; color:blue;">
                [voir moins]
            </span>
        </span>
    {% else %}
        {{ comment.description }}
    {% endif %}
    <br>
    {% for child in comment.children %}
        {% include 'topic/_comment_tree.html.twig' with {
            comment: child,
        } %}
    {% endfor %}
</span>

<script>
    function toggleComment(e) {
        const wrapper = e.closest('span[class]').parentElement;
        const short = wrapper.querySelector('.comment-short');
        const full = wrapper.querySelector('.comment-full');
        short.style.display = short.style.display === 'none' ? 'inline' : 'none';
        full.style.display = full.style.display === 'none' ? 'inline' : 'none';
    }
</script>
