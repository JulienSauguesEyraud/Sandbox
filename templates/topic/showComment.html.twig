{% extends 'base.html.twig' %}

{% block body %}

    <h1>Sujet : {{ topic.title }}</h1>
    <p>{{ comment.description }}</p>

    {% for child in comment.children %}
        {% include 'topic/_comment_tree.html.twig' with {
            comment: child,
        } %}
    {% endfor %}

    <a href="{{ path('topic_show', {'id': topic.id }) }}">Retour</a>
    <a href="{{ path('app_root') }}">Accueil</a>

{% endblock %}
